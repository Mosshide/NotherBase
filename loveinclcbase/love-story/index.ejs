<style>
    <%- include('./index.css'); %>
</style>

<section>
    <div class="love-story <%= query.story ? query.story : '' %>">
        <a href="/" class="external inverted"><i class="fa-solid fa-left-long"></i>Return to Home</a>
        <% if (query.story) { %>
            <!-- add more cases to publish a story -->
            <%- include(`./stories/${query.story}.ejs`); %>
        <% } else { %>
            <h3>Not Found</h3>
        <% } %>
    </div>
</section>

<script src="/js/themeApplicator.js"></script>
<script>
    const themeApplicator = new ThemeApplicator();

    base.do("tally", { route: "/scripts" });
    setTimeout(() => {
        setInterval(() => {
            base.do("tally-extra", { route: "/scripts" });
        }, 30000);
    }, 3000);
</script>